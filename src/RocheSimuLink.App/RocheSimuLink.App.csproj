<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>RocheSimuLink</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Product metadata, surfaced in the executable and the installer. -->
    <AssemblyTitle>Roche SimuLink</AssemblyTitle>
    <Product>Roche SimuLink</Product>
    <Company>Roche Diagnostics International</Company>
    <Version>1.0.5</Version>
    <AssemblyVersion>1.0.5.0</AssemblyVersion>
    <FileVersion>1.0.5.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\RocheSimuLink.Core\RocheSimuLink.Core.csproj" />
  </ItemGroup>

  <!-- Bundle the Host Interface Manual next to the executable so the app ships
       with a default assay catalog. Linked from the repo root to avoid
       duplicating the PDF; SettingsLoader parses it at startup. -->
  <ItemGroup>
    <None Include="..\..\HIMv2_1.pdf" Link="HIMv2_1.pdf" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Bundle brand assets (Roche logo) next to the executable; loaded at
       runtime by the toolbar. -->
  <ItemGroup>
    <None Include="Assets\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
